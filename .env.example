# Database Configuration
DATABASE_URL=postgresql://iotproxy:iotproxy@localhost:5432/iotproxy
POSTGRES_DB=iotproxy
POSTGRES_USER=iotproxy
POSTGRES_PASSWORD=iotproxy

# Redis Configuration
REDIS_BULL_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6380/0

# MQTT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883

# JWT Configuration
JWT_SECRET=change-me-to-a-random-32-char-minimum-secret-key
JWT_REFRESH_SECRET=change-me-to-another-random-32-char-minimum-secret

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=iotproxy-exports

# SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=noreply@iotproxy.io
SMTP_PASS=unused

# Application Configuration
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
POD_NAME=local

# Frontend Configuration (Vite)
VITE_API_TARGET=http://localhost:3000
VITE_WS_TARGET=ws://localhost:3000
